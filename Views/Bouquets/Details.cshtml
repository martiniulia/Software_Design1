@model FlowerShop.Models.Bouquet
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Name;
}

<div style="max-width: 1100px; margin: 40px auto; padding: 0 20px; font-family: 'Segoe UI', sans-serif;">

    @* Back button (same style as flowers) *@
    <div style="margin-bottom: 20px;">
        <a href="/Bouquets" style="text-decoration: none; color: #666; font-size: 0.9rem; display: flex; align-items: center; gap: 5px;">
            ← Back to Bouquets
        </a>
    </div>

    <div style="display: flex; gap: 50px; background: white; padding: 40px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #f0f0f0;">

        @* Image *@
        <div style="flex: 1;">
            <div style="width: 100%; height: 500px; border-radius: 12px; overflow: hidden; background: #fcfcfc;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                        <img src="/@Model.ImageUrl" 
                             style="width: 100%; height: 100%; object-fit: cover;" 
                             onerror="this.src='/no-image.png'" />
                }
            </div>
        </div>

        @* Details *@
        <div style="flex: 1; display: flex; flex-direction: column; justify-content: center;">
            <h1 style="font-family: 'Playfair Display', serif; font-size: 3rem; color: #1a2e1a; margin-bottom: 10px;">@Model.Name</h1>

            <div style="font-size: 2rem; color: #2d4a2d; font-weight: bold; margin-bottom: 20px;">
                @Model.Price.ToString("F2") RON
            </div>

            <p style="color: #666; line-height: 1.6; margin-bottom: 30px;">@Model.Description</p>

            <form asp-controller="Cart" asp-action="AddToCart" method="post" style="margin-bottom: 24px;">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="productType" value="bouquet" />
                <input type="hidden" name="quantity" value="1" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                <button type="submit" style="background: #1a2e1a; color: white; border: none; padding: 14px 24px; border-radius: 6px; font-weight: bold; cursor: pointer;">
                    Add to Cart
                </button>
            </form>

            @* Arrangement includes section *@
            <div style="background: #f9f9f9; padding: 25px; border-radius: 10px; border: 1px solid #eee;">
                <h4 style="margin-top: 0; color: #1a2e1a; border-bottom: 1px solid #ddd; padding-bottom: 10px;">Arrangement Includes:</h4>

                @if (Model.BouquetFlowers != null && Model.BouquetFlowers.Any())
                {
                        <ul style="list-style: none; padding: 0; margin: 0;">
                        @foreach (var item in Model.BouquetFlowers)
                        {
                                    <li style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed #eee;">
                                        <span><strong>@item.Quantity x</strong> @item.Flower.Name</span>
                                    </li>
                        }
                        </ul>
                }
                else
                {
                        <p style="color: #999; font-style: italic;">No flower details added yet for this bouquet.</p>
                }
            </div>
        </div>
    </div>
</div>