@model FlowerShop.Models.Bouquet
@{
    Layout = "_Layout";
    ViewData["Title"] = "New Bouquet";
    var flowers = ViewBag.Flowers as IEnumerable<FlowerShop.Models.Flower> ?? Enumerable.Empty<FlowerShop.Models.Flower>();
}

<div style="max-width: 720px; margin: 40px auto; padding: 0 20px;">
    <a href="/Bouquets" style="text-decoration: none; color: #666; font-size: 0.9rem; display: inline-flex; margin-bottom: 24px;">← Back to Bouquets</a>
    <h2 style="font-family: 'Playfair Display', serif; color: #1a2e1a;">New Bouquet</h2>

    <form asp-action="Create" method="post" style="display: grid; gap: 16px; font-family: 'Segoe UI', sans-serif;">
        <div asp-validation-summary="All" style="color: #b35353;"></div>
        <div>
            <label>Name</label><br />
            <input asp-for="Name" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
        </div>
        <div>
            <label>Price (RON)</label><br />
            <input asp-for="Price" type="number" step="0.01" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
        </div>
        <div>
            <label>Description</label><br />
            <textarea asp-for="Description" rows="3" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"></textarea>
        </div>
        <div>
            <label>Occasion tag</label><br />
            <input asp-for="OccasionTag" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
        </div>
        <div>
            <label>Image URL</label><br />
            <input asp-for="ImageUrl" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
        </div>

        <h3 style="font-family: 'Playfair Display', serif; color: #1a2e1a; margin-top: 8px;">Flowers in bouquet</h3>
        <p style="color: #666; font-size: 0.9rem;">Set quantity &gt; 0 for each flower to include.</p>
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="text-align: left; border-bottom: 1px solid #eee;">
                    <th style="padding: 8px;">Flower</th>
                    <th style="padding: 8px; width: 120px;">Qty</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var f in flowers)
            {
                <tr style="border-bottom: 1px solid #f5f5f5;">
                    <td style="padding: 8px;">@f.Name <span style="color:#888;">(@f.Category?.Name)</span></td>
                    <td style="padding: 8px;">
                        <input type="hidden" name="flowerIds" value="@f.Id" />
                        <input type="number" name="quantities" value="0" min="0" style="width: 100%; padding: 6px;" />
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <button type="submit" style="background: #1a2e1a; color: #fff; border: none; padding: 12px; border-radius: 4px; cursor: pointer;">Create bouquet</button>
    </form>
</div>
