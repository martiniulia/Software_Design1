@model FlowerShop.Models.Bouquet
@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit " + Model.Name;
}

<div style="max-width: 640px; margin: 40px auto; padding: 0 20px;">
    <a href="/Bouquets" style="text-decoration: none; color: #666; font-size: 0.9rem; display: inline-flex; margin-bottom: 24px;">← Back to Bouquets</a>
    <h2 style="font-family: 'Playfair Display', serif; color: #1a2e1a;">Edit Bouquet</h2>
    <p style="color: #666; font-size: 0.9rem;">Edit the basic bouquet fields here. For flower recipe management, use a dedicated flow.</p>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" style="display: grid; gap: 16px; font-family: 'Segoe UI', sans-serif;">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" style="color: #b35353;"></div>
        <div>
            <label>Name</label><br />
            <input asp-for="Name" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
        </div>
        <div>
            <label>Price (RON)</label><br />
            <input asp-for="Price" type="number" step="0.01" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
        </div>
        <div>
            <label>Description</label><br />
            <textarea asp-for="Description" rows="3" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"></textarea>
        </div>
        <div>
            <label>Occasion tag</label><br />
            <input asp-for="OccasionTag" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
        </div>
        <div>
            <label>Image URL</label><br />
            <input asp-for="ImageUrl" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" />
        </div>
        <button type="submit" style="background: #1a2e1a; color: #fff; border: none; padding: 12px; border-radius: 4px; cursor: pointer;">Save</button>
    </form>
</div>
