@model FlowerShop.Models.Category
@{
    ViewData["Title"] = "Edit Category";
}

@if (Context.Session.GetString("UserRole") == "Admin")
{
    <p style="margin-bottom: 12px;"><a href="/Admin/Categories" style="color:#666;text-decoration:none;">← Back to Management</a></p>
}

<h2 style="font-family:'Playfair Display',serif;color:#1a2e1a;">Edit Category</h2>

<form method="post" style="max-width:640px;display:grid;gap:14px;background:#fff;border:1px solid #ececec;border-radius:8px;padding:16px;font-family:'Segoe UI',sans-serif;">
    <div asp-validation-summary="All" style="color:#b35353"></div>
    
    <input type="hidden" asp-for="Id" />
    
    <div>
        <label>Name</label><br />
        <input asp-for="Name" required style="width:100%;height:42px;padding:0 10px;border:1px solid #ddd;border-radius:4px;" />
        <span asp-validation-for="Name" style="color:red"></span>
    </div>
    
    <div>
        <label>Description</label><br />
        <textarea asp-for="Description" rows="3" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;"></textarea>
    </div>

    <div style="display:flex;gap:8px;">
        <button type="submit" style="height:42px;min-width:120px;background:#1a2e1a;color:#fff;border:none;border-radius:4px;cursor:pointer;">Save Changes</button>
        <a href="/Admin/Categories" style="height:42px;min-width:120px;display:inline-flex;align-items:center;justify-content:center;border:1px solid #1a2e1a;color:#1a2e1a;text-decoration:none;border-radius:4px;">Cancel</a>
    </div>
</form>
