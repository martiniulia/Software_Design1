@model FlowerShop.Models.Category
@{
    ViewData["Title"] = "Create Category";
}

@if (Context.Session.GetString("UserRole") == "Admin")
{
    <p style="margin-bottom: 12px;"><a href="/Admin/Categories" style="color:#666;text-decoration:none;">← Back to Management</a></p>
}

<h2>Create Category</h2>

<form method="post">
    <div asp-validation-summary="All" style="color:red"></div>
    
    <div>
        <label>Name:</label><br />
        <input asp-for="Name" required />
        <span asp-validation-for="Name" style="color:red"></span>
    </div>
    
    <div>
        <label>Description:</label><br />
        <textarea asp-for="Description" rows="3"></textarea>
    </div>
    
    <br />
    <button type="submit">Create</button>
    <a href="/Categories">Cancel</a>
</form>
