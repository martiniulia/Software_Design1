@{
    ViewData["Title"] = "Login";
}

<div style="max-width: 360px; margin: 80px auto; padding: 0 20px;">

    <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--green-dark);">Login</h2>
        <p style="color: var(--text-light); font-size: 0.9rem; margin-top: 8px;">Access your Flower Shop account</p>
    </div>

    @if (ViewBag.Error != null)
    {
            <div class="alert alert-danger" style="margin-bottom: 20px; text-align: center;">
            @ViewBag.Error
            </div>
    }

    <form method="post" style="display: flex; flex-direction: column; gap: 20px;">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-control" placeholder="your@email.com" required />
        </div>

        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Password</label>
            <input name="password" type="password" class="form-control" placeholder="••••••••" required />
        </div>

        <button type="submit" class="btn btn-primary" style="justify-content: center; padding: 12px; margin-top: 10px;">
            Sign In
        </button>
    </form>

    <div style="text-align: center; margin-top: 30px;">
        <a href="/Account/Register" style="color: var(--text-muted); font-size: 0.85rem; text-decoration: none; border-bottom: 1px solid var(--border);">
            New here? Create an account
        </a>
    </div>

</div>