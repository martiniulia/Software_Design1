@model FlowerShop.Models.Florist
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">@Model.Name</h1>
    <div class="actions">
        <a href="/Florists" class="btn btn-secondary">← Back</a>
        @if (ViewBag.IsAdmin == true)
        {
                <a href="/Florists/Edit/@Model.Id" class="btn btn-primary">Edit</a>
        }
    </div>
</div>

<div class="card">
    <div class="form-row">
        <div class="form-group">
            <span class="form-label">Specialization</span>
            <p>@(Model.Specialization ?? "—")</p>
        </div>
        <div class="form-group">
            <span class="form-label">Email</span>
            <p>@(Model.ContactEmail ?? "—")</p>
        </div>
        <div class="form-group">
            <span class="form-label">Phone</span>
            <p>@(Model.Phone ?? "—")</p>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Bio))
    {
            <div class="form-group" style="margin-top:0.5rem">
                <span class="form-label">Bio</span>
                <p>@Model.Bio</p>
            </div>
    }
</div>

<h2 class="page-title" style="font-size:1.25rem; margin-bottom:1rem">Assigned Flowers (@Model.Flowers.Count)</h2>

@if (Model.Flowers.Any())
{
        <div class="card">
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Category</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var flower in Model.Flowers)
                    {
                                <tr>
                                    <td><a href="/Flowers/Details/@flower.Id">@flower.Name</a></td>
                                    <td>@flower.Price.ToString("F2") RON</td>
                                    <td>@flower.StockQuantity</td>
                                    <td>@(flower.Category?.Name ?? "—")</td>
                                </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
}
else
{
        <div class="card">
            <div class="empty-state">
                <p>No flowers are assigned to this florist.</p>
            </div>
        </div>
}

@if (ViewBag.IsAdmin == true)
{
        <form method="post" action="/Florists/Delete/@Model.Id" style="margin-top:1rem">
            <button type="submit" class="btn btn-danger"
                    onclick="return confirm('Are you sure you want to delete this florist?')">Delete Florist</button>
        </form>
}
