@model FlowerShop.Models.Florist
@{
    ViewData["Title"] = "Add Florist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h1 class="page-title">Add Florist</h1>
    <a href="/Florists" class="btn btn-secondary">← Back</a>
</div>

<div class="card" style="max-width: 600px;">
    <form method="post">
        <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Name *</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" style="color:var(--danger);font-size:0.8rem"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Specialization</label>
                <input asp-for="Specialization" class="form-control" placeholder="e.g. roses, wedding bouquets" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Email</label>
                <input asp-for="ContactEmail" type="email" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Phone</label>
                <input asp-for="Phone" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Bio</label>
            <textarea asp-for="Bio" class="form-control" rows="3" placeholder="Short description..."></textarea>
        </div>

        <div class="actions" style="margin-top:0.5rem">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/Florists" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
